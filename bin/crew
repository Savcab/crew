#!/usr/bin/env python3
"""crew CLI entrypoint. Put this dir on PATH (or symlink it) and run `crew ...`.
Adds the repo root to sys.path so the `crew` package imports without install."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from crew.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
